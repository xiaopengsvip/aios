{
  "name": "ai-workspace-os",
  "version": "0.0.8",
  "private": true,
  "description": "AI Workspace OS - 企业级 AI 超级工作台",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3100",
    "build": "next build",
    "start": "next start -H 127.0.0.1 -p ${PORT:-3100}",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "test:smtp": "tsx scripts/test-smtp.ts",
    "queue:worker": "tsx scripts/queue-worker.ts"
  },
