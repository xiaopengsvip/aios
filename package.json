    "bullmq": "^5.30.0",
    "cookie": "^1.1.1",
    "crypto-js": "^4.2.0",
    "framer-motion": "^12.38.0",
    "i18next": "^25.2.0",
    "jsonwebtoken": "^9.0.3",
    "next": "15.3.3",
    "next-intl": "^4.3.0",
    "nodemailer": "^8.0.7",
    "openai": "^4.100.0",
    "prisma": "^6.19.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
