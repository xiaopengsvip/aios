# ============================================================
# AI Workspace OS - 环境变量配置
# ============================================================

# --- 基础配置 ---
NODE_ENV=development
APP_URL=https://aios.allapple.top
APP_NAME=AI Workspace OS
APP_NAME_CN=AI 工作台

# --- 数据库 ---
DATABASE_URL=postgresql://user:CHANGE_ME@localhost:5432/aios_db

# --- Redis ---
REDIS_URL=redis://localhost:6379
SMTP_PASS=your-smtp-password
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=AI Workspace OS
TEST_EMAIL=test@example.com

# --- Security Keys ---
ENCRYPTION_KEY=CHANGE_ME_TO_RANDOM_STRING
ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# --- AI Provider Keys (加密存储在数据库，这里放备用默认) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
QWEN_API_KEY=
SILICONFLOW_API_KEY=
OPENROUTER_API_KEY=

# --- 文件存储 ---
STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aios

# --- 向量数据库 ---
QDRANT_URL=http://localhost:6333

# --- 监控 ---
SENTRY_DSN=

# --- 安全 ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
WAF_ENABLED=true

# --- 队列 ---
BULLMQ_REDIS_URL=redis://localhost:6379
