{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for AIOS",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "description": "Allow HTTP requests to AIOS API servers",
      "allow": [
        { "url": "https://aios.vios.top/**" },
        { "url": "https://aios.allapple.top/**" }
      ]
    }
  ]
}
